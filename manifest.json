{
  "manifest_version": 3,
  "name": "学习通网课助手 (Chaoxing Course Helper)",
  "version": "1.0.0",
  "description": "自动视频播放、倍速、静音、章节测验答题（预留自定义题库API接口）、自动跳转下一节",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.chaoxing.com/*",
    "*://*.edu.cn/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "popup/popup.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.edu.cn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content/start_inject.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.edu.cn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/widget.css"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/inject.js", "content/finish_hook.js"],
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.edu.cn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ]
}
